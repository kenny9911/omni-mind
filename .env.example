# OmniMind backend configuration

# Database (libSQL / SQLite). Local default is a file under .data/.
# For Turso/Neon in prod, set the remote URL + auth token.
DATABASE_URL="file:./.data/omnimind.db"
# DATABASE_AUTH_TOKEN=""

# Every account (including demo) uses real models — there is no mock engine.
# Configure at least one provider below or chats return GATEWAY_NOT_CONFIGURED.

# --- LLM providers (Option A: layered resolution) -----------------------------
# Per model, the call tries candidates in order and falls through on a pre-output
# error:  1) your DEDICATED key (cheapest/direct)  →  2) OpenRouter (one key,
# verified slugs for every model)  →  3) Vercel AI Gateway. Real (non-demo) chats
# need at least ONE of these configured, else a clear GATEWAY_NOT_CONFIGURED error.
#
# Dedicated keys (direct, no markup). Covers 9 of 12 models:
# OPENAI_API_KEY=""        # gpt-55, gpt-mini
# ANTHROPIC_API_KEY=""     # claude-opus  (via Anthropic's OpenAI-compatible endpoint)
# GEMINI_API_KEY=""        # gemini-pro, gemini-flash
# DEEPSEEK_API_KEY=""      # deepseek-pro, deepseek-flash
# GLM_API_KEY=""           # glm  (Zhipu, OpenAI-compatible)
# KIMI_API_KEY=""          # kimi (Moonshot .cn, OpenAI-compatible)
#
# OpenRouter — one key, serves ALL 12 models (primary for qwen/doubao/minimax,
# fallback for the rest). Recommended so nothing depends on the Vercel gateway:
# OPENROUTER_API_KEY=""
#
# Vercel AI Gateway — final fallback; one key reaches all models (OIDC on Vercel):
# AI_GATEWAY_API_KEY=""
#
# Per-provider model ids + OpenRouter slugs live in lib/server/llm/providers.ts.
# LLM_FORCE_GATEWAY="1"    # ignore all direct/OpenRouter keys; gateway only (A/B switch)

# System accounts are auto-seeded on first DB init / `npm run db:migrate` (both clean, real):
#   demo / demo123              → real account; isDemo only = read-only profile + no-delete
#   admin@robohire.io / Lightark@1 → role=admin (full user management)

# Platform fee charged per model call, in CNY.
PLATFORM_FEE_CNY="0.05"

# Context memory ("context engineering"): a compact, bounded per-user memory of
# distilled facts, injected as a tiny preamble into real (non-demo) chats.
# MEMORY_MODEL="deepseek-flash"   # cheap non-reasoning model used to distill facts
# MEMORY_DISABLED="1"             # turn OFF learning + injection entirely
# SUGGESTIONS_MODEL="deepseek-flash"  # cheap model behind GET /api/suggestions

# Session cookie signing / app secret (set a long random value in real envs).
APP_SECRET="dev-only-insecure-secret-change-me"
